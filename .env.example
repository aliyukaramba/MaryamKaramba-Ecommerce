# ==========================================
# DATABASE
# ==========================================
DATABASE_URL="postgresql://user:password@localhost:5432/whatsapp_commerce?schema=public"

# Required if your Postgres provider uses connection pooling (e.g. Neon, PgBouncer).
# This must be the DIRECT (non-pooled) connection string — Prisma Migrate can't
# run migrations through a pooled connection. Runtime queries still use
# DATABASE_URL above (the pooled one), which is what you want on Vercel.
# If your provider doesn't pool connections, just set this to the same value
# as DATABASE_URL.
DIRECT_URL="postgresql://user:password@localhost:5432/whatsapp_commerce?schema=public"

# ==========================================
# AUTH.JS (NextAuth v5)
# ==========================================
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Separate secret for customer account sessions (optional login on the
# storefront) — deliberately independent from AUTH_SECRET above, so a
# compromise of one session system doesn't affect the other. Falls back to
# AUTH_SECRET if left unset, but a distinct value is recommended.
# Generate with: openssl rand -base64 32
CUSTOMER_AUTH_SECRET="generate-a-different-secret-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ==========================================
# CLOUDINARY (image storage)
# ==========================================
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="whatsapp_commerce_unsigned"

# ==========================================
# WHATSAPP
# ==========================================
WHATSAPP_NUMBER="2348012345678"
NEXT_PUBLIC_WHATSAPP_NUMBER="2348012345678"

# ==========================================
# SITE
# ==========================================
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Your Store Name"

# ==========================================
# EMAIL (optional — Resend)
# ==========================================
RESEND_API_KEY=""
EMAIL_FROM="orders@yourdomain.com"
ADMIN_NOTIFICATION_EMAIL="admin@yourdomain.com"
ENABLE_EMAIL_NOTIFICATIONS="false"

# ==========================================
# RATE LIMITING (optional — Upstash Redis)
# ==========================================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ==========================================
# DEFAULT ADMIN (used by seed script only)
# ==========================================
DEFAULT_ADMIN_EMAIL="admin@example.com"
DEFAULT_ADMIN_PASSWORD="Admin123!"
