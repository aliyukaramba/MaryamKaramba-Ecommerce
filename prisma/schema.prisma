// ============================================================================
// WhatsApp Commerce Platform — Prisma Schema
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum Role {
  SUPER_ADMIN
  ADMIN
  STAFF
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum InquiryStatus {
  NEW
  PENDING
  CONTACTED
  CONFIRMED
  PACKING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum StockMovementType {
  RESTOCK
  SALE
  ADJUSTMENT
  RETURN
  DAMAGE
}

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  STATUS_CHANGE
}

// ============================================================================
// AUTH / USER
// ============================================================================

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  password      String
  role          Role      @default(STAFF)
  image         String?
  isActive      Boolean   @default(true)

  resetToken       String?
  resetTokenExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activityLogs ActivityLog[]
  accounts     Account[]
  sessions     Session[]

  @@index([email])
  @@map("users")
}

// Auth.js required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================================
// CATALOG
// ============================================================================

model Category {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String? @db.Text
  image       String?
  parentId    String?
  order       Int     @default(0)
  isActive    Boolean @default(true)

  seoTitle       String?
  seoDescription String? @db.Text

  parent   Category?  @relation("CategoryToSubcategory", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryToSubcategory")
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([parentId])
  @@map("categories")
}

model Product {
  id                String        @id @default(cuid())
  name              String
  slug              String        @unique
  sku               String        @unique
  barcode           String?
  brand             String?
  description       String        @db.Text
  shortDescription  String?
  price             Decimal       @db.Decimal(12, 2)
  salePrice         Decimal?      @db.Decimal(12, 2)
  featuredImage     String
  images            String[]      @default([])
  stock             Int           @default(0)
  lowStockThreshold Int           @default(5)
  weight            Float?
  tags              String[]      @default([])
  colors            String[]      @default([])
  sizes             String[]      @default([])
  status            ProductStatus @default(DRAFT)

  isFeatured    Boolean @default(false)
  isTrending    Boolean @default(false)
  isNewArrival  Boolean @default(true)

  viewCount    Int @default(0)
  clickCount   Int @default(0)
  contactCount Int @default(0)

  seoTitle       String?
  seoDescription String? @db.Text
  seoKeywords    String[] @default([])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  variants      ProductVariant[]
  inventoryLogs Inventory[]
  inquiryItems  InquiryItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([sku])
  @@index([categoryId])
  @@index([status])
  @@index([isFeatured])
  @@index([isTrending])
  @@map("products")
}

model ProductVariant {
  id             String  @id @default(cuid())
  productId      String
  color          String?
  size           String?
  sku            String  @unique
  quantity       Int     @default(0)
  priceAdjustment Decimal @default(0) @db.Decimal(12, 2)
  image          String?
  isActive       Boolean @default(true)

  product      Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  inquiryItems InquiryItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@map("product_variants")
}

model Inventory {
  id           String            @id @default(cuid())
  productId    String
  type         StockMovementType
  quantity     Int
  previousStock Int
  newStock     Int
  reason       String?
  reference    String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([productId])
  @@map("inventory_logs")
}

// ============================================================================
// CUSTOMER / INQUIRY
// ============================================================================

model Customer {
  id              String  @id @default(cuid())
  fullName        String
  phone           String
  email           String?
  deliveryCity    String
  deliveryAddress String?
  notes           String? @db.Text

  inquiries Inquiry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@map("customers")
}

model Inquiry {
  id            String        @id @default(cuid())
  inquiryNumber String        @unique
  customerId    String
  status        InquiryStatus @default(NEW)
  notes         String?       @db.Text
  totalAmount   Decimal       @db.Decimal(12, 2)
  whatsappSent  Boolean       @default(false)

  customer Customer      @relation(fields: [customerId], references: [id])
  items    InquiryItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([inquiryNumber])
  @@index([customerId])
  @@index([status])
  @@map("inquiries")
}

model InquiryItem {
  id         String  @id @default(cuid())
  inquiryId  String
  productId  String
  variantId  String?
  quantity   Int
  unitPrice  Decimal @db.Decimal(12, 2)
  totalPrice Decimal @db.Decimal(12, 2)
  color      String?
  size       String?

  inquiry Inquiry         @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([inquiryId])
  @@index([productId])
  @@map("inquiry_items")
}

// ============================================================================
// SITE CONFIGURATION
// ============================================================================

model HomepageSettings {
  id String @id @default(cuid())

  heroTitle       String?
  heroSubtitle    String?
  heroImage       String?
  heroCtaText     String?
  heroCtaLink     String?

  bannerImages String[] @default([])

  faqs         Json? // [{ question, answer }]
  testimonials Json? // [{ name, avatar, rating, text }]

  showFeatured   Boolean @default(true)
  showTrending   Boolean @default(true)
  showNewArrival Boolean @default(true)

  updatedAt DateTime @updatedAt

  @@map("homepage_settings")
}

model BusinessSettings {
  id String @id @default(cuid())

  businessName  String
  logo          String?
  favicon       String?
  whatsappNumber String
  businessEmail String?
  businessPhone String?
  address       String?

  facebookUrl  String?
  instagramUrl String?
  twitterUrl   String?
  tiktokUrl    String?

  currency String @default("NGN")
  currencySymbol String @default("₦")
  timezone String @default("Africa/Lagos")

  primaryColor   String @default("#000000")
  secondaryColor String @default("#ffffff")

  updatedAt DateTime @updatedAt

  @@map("business_settings")
}

// ============================================================================
// ANALYTICS / ACTIVITY
// ============================================================================

model ActivityLog {
  id     String         @id @default(cuid())
  userId String?
  action ActivityAction
  entity String
  entityId String?
  details Json?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@map("activity_logs")
}

model Analytics {
  id        String   @id @default(cuid())
  date      DateTime @default(now()) @db.Date
  pageViews Int      @default(0)
  productViews Int   @default(0)
  inquiries Int      @default(0)
  whatsappClicks Int @default(0)
  topProductId String?

  createdAt DateTime @default(now())

  @@unique([date])
  @@map("analytics")
}

model Newsletter {
  id           String   @id @default(cuid())
  email        String   @unique
  isSubscribed Boolean  @default(true)

  createdAt DateTime @default(now())

  @@map("newsletter_subscribers")
}
